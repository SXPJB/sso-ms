  <diagram name="C4 Component Diagram" id="c4-component-smal-ms">
    <mxGraphModel dx="1234" dy="847" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ct-title" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;smal-ms — C4 Component Diagram&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;i&gt;SAML 2.0 SSO Token Generation &amp;amp; Verification&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=JetBrains Mono;" parent="1" vertex="1">
          <mxGeometry x="40" y="20" width="780" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ct-client" value="&lt;b&gt;External Client&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Person / System]&lt;/i&gt;" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontFamily=JetBrains Mono;" parent="1" vertex="1">
          <mxGeometry x="505" y="90" width="40" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ct-container" value="&lt;b&gt;smal-ms&lt;/b&gt; &lt;i&gt;[Spring Boot Microservice]&lt;/i&gt;&lt;br&gt;SAML 2.0 SSO Authentication Service" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#6c8ebf;strokeWidth=2;fontFamily=JetBrains Mono;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="50" y="210" width="1000" height="870" as="geometry" />
        </mxCell>
        <mxCell id="ct-ctrl" value="&lt;b&gt;SsoController&lt;/b&gt;&lt;br&gt;&lt;i&gt;[REST Component]&lt;/i&gt;&lt;br&gt;&lt;br&gt;POST /v1/sso/generate-token&lt;br&gt;POST /v1/sso/verify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=JetBrains Mono;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="375" y="280" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ct-svc" value="&lt;b&gt;SsoService&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Service Component]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Orchestrates token operations and delegates to core layer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=JetBrains Mono;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="375" y="440" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ct-gen" value="&lt;b&gt;GenerateSsoTokenDelegate&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Builds SAML token and calculates expiry. Returns GenerateTokenResponse (token, tokenType, expiresAt)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=JetBrains Mono;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="70" y="620" width="290" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ct-ver" value="&lt;b&gt;VerifySsoTokenDelegate&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Decodes token and extracts assertion data. Throws SAMLException(401 UNAUTHORIZED) on any failure." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=JetBrains Mono;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="690" y="620" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ct-rsa" value="&lt;b&gt;RsaAssertionHelper&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Signs (RSA-SHA256), encrypts (AES-256-GCM + RSA-OAEP key transport), decrypts and verifies SAML assertions. Encodes / decodes Base64." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=JetBrains Mono;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="375" y="810" width="300" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ct-xml" value="&lt;b&gt;SamlXmlHelper&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Builds, wraps, parses and extracts data from raw SAML XML objects (Assertions, Subjects, Conditions, Responses)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=JetBrains Mono;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="375" y="990" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ct-note" value="&lt;b&gt;Config:&lt;/b&gt;&lt;br&gt;app.saml.rsa.private-key (PKCS8)&lt;br&gt;app.saml.rsa.certificate (X.509)&lt;br&gt;Both injected as Base64 strings" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#ffe6cc;strokeColor=#d79b00;fontFamily=JetBrains Mono;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="740" y="810" width="260" height="90" as="geometry" />
        </mxCell>
        <mxCell id="ce-1" value="HTTP POST&lt;br&gt;&lt;i&gt;[JSON/HTTPS]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;" parent="1" source="ct-client" target="ct-ctrl" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce-2" value="delegates&lt;br&gt;&lt;i&gt;[Method Call]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;" parent="1" source="ct-ctrl" target="ct-svc" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce-3" value="generateToken()&lt;br&gt;&lt;i&gt;[Method Call]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;edgeStyle=orthogonalEdgeStyle;" parent="1" source="ct-svc" target="ct-gen" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce-4" value="verifyToken()&lt;br&gt;&lt;i&gt;[Method Call]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;edgeStyle=orthogonalEdgeStyle;" parent="1" source="ct-svc" target="ct-ver" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce-5" value="buildToken()&lt;br&gt;&lt;i&gt;[Method Call]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;edgeStyle=orthogonalEdgeStyle;entryX=0.2;entryY=0;entryDx=0;entryDy=0;" parent="1" source="ct-gen" target="ct-rsa" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce-6" value="verifyAndDecode()&lt;br&gt;&lt;i&gt;[Method Call]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;edgeStyle=orthogonalEdgeStyle;entryX=0.8;entryY=0;entryDx=0;entryDy=0;" parent="1" source="ct-ver" target="ct-rsa" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce-7" value="build / parse SAML XML&lt;br&gt;&lt;i&gt;[Method Call]&lt;/i&gt;" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;fontFamily=JetBrains Mono;endSize=8;labelBackgroundColor=none;" parent="1" source="ct-rsa" target="ct-xml" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
